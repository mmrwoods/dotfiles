" Toned down powerlineish theme
let g:airline_theme = 'powerlineish'
let g:airline_theme_patch_func = 'AirlineThemePatch'
function! AirlineThemePatch(palette)
  if g:airline_theme == 'powerlineish'
    let a:palette.normal.airline_c = a:palette.normal.airline_b
    let a:palette.normal.airline_x = a:palette.normal.airline_b
    let a:palette.replace.airline_c = a:palette.replace.airline_b
    let a:palette.replace.airline_x = a:palette.replace.airline_b
    let a:palette.inactive = airline#themes#generate_color_map(a:palette.normal.airline_b, a:palette.normal.airline_b, a:palette.normal.airline_b)
  endif
endfunction

